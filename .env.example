# Token do bot Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=

# ID do canal privado (ex: -1001234567890)
TELEGRAM_CHANNEL_ID=

# Link fixo de convite do canal privado
TELEGRAM_CHANNEL_LINK=

# Preços em centavos (R$ 29,90 e R$ 299,00)
PRICE_MONTHLY_CENTS=2990
PRICE_YEARLY_CENTS=29900

# URL pública do servidor (Railway em produção, URL ngrok em desenvolvimento)
WEBHOOK_BASE_URL=

# ID do admin no Telegram para receber notificações de venda
ADMIN_TELEGRAM_ID=

# Credenciais EFI Bank (Gerencianet)
# Client ID e Client Secret obtidos em: https://sejaefi.com.br → Minha Conta → Aplicações
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=

# Chave Pix cadastrada na conta EFI (CPF, CNPJ, email ou chave aleatória)
EFI_PIX_KEY=

# Caminho para o certificado .p12 baixado no painel EFI
EFI_CERT_PATH=./certificado.p12

# true = ambiente sandbox (testes), false = produção real
EFI_SANDBOX=false
